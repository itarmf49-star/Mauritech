generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  CUSTOMER
}

model User {
  id String @id @default(cuid())
  name     String?
  email    String   @unique
  password String
  role     Role     @default(CUSTOMER)

  phone    String?
  info     String?

  accounts Account[]
  sessions Session[]

  billingInvoices BillingInvoice[]
  clientAccounts ClientAccount[]
  messages Message[]
  chatMessages ChatMessage[]
  aiConversations AiConversation[]
  coveragePlans CoveragePlan[]
  portalProjects PortalProject[]
  supportTickets SupportTicket[]
  portalDocuments PortalDocument[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String?
  category    String?
  description String?
  imageUrl    String?
  videoUrl    String?
  isPublished Boolean  @default(true)

  translations ProjectTranslation[]
  images       ProjectImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model ProjectTranslation {
  id          String @id @default(cuid())
  projectId   String
  locale      String
  title       String
  description String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@index([locale])
}

model ProjectImage {
  id        String   @id @default(cuid())
  url       String
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  subject   String?
  body      String
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt])
  @@map("Message")
}

model SiteSettings {
  id        String  @id @default(cuid())
  siteName  String  @default("MauriTech")
  seoTitle  String?
  seoDesc   String?
  ogImage   String?
  facebook  String?
  instagram String?
  x         String?
  youtube   String?

  updatedAt DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model ClientAccount {
  id        String   @id @default(cuid())
  userId    Int      @unique
  company   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  invoices Invoice[]

  @@index([userId])
  @@map("PortalAccount")
}  

model Invoice {
  id        String   @id @default(cuid())
  accountId String
  amount    Float
  status    String   @default("pending")
  issuedAt  DateTime @default(now())

  account ClientAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  items   InvoiceItem[]

  @@index([accountId])
  @@index([status])
  @@index([issuedAt])
  @@map("PortalInvoice")
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String
  title     String
  price     Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("PortalInvoiceItem")
}

model Message {
  id        String   @id @default(cuid())
  userId    Int
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("PortalMessage")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

model BillingInvoice {
  id        String        @id @default(cuid())
  userId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    InvoiceStatus @default(DRAFT)
  currency  String        @default("MRU")
  subtotal  Int           @default(0)
  tax       Int           @default(0)
  total     Int           @default(0)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items BillingInvoiceItem[]

  @@index([userId])
  @@index([status])
  @@map("Invoice")
}

model BillingInvoiceItem {
  id          String         @id @default(cuid())
  invoiceId   String
  invoice     BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int            @default(1)
  unitPrice   Int
  total       Int

  @@index([invoiceId])
  @@map("InvoiceItem")
}

model ServiceProduct {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  description   String
  basePrice     Int
  currency      String  @default("MRU")
  specs         Json?
  isActive      Boolean @default(true)
  postsIncluded Int     @default(0)
  color         String?
  location      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PricingRule {
  id        String  @id @default(cuid())
  name      String
  priority  Int     @default(0)
  match     Json
  price     Int
  currency  String  @default("MRU")
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model ChatThread {
  id        String        @id @default(cuid())
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  senderId  Int?
  sender    User?      @relation(fields: [senderId], references: [id])

  body      String
  isAi      Boolean    @default(false)

  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([createdAt])
}

model AiConversation {
  id        String   @id @default(cuid())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String
  content String

  createdAt DateTime @default(now())

  @@index([conversationId])
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    Int?
  model     String
  tokens    Int      @default(0)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id        String @id @default(cuid())
  actorId   Int?
  action    String
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}  

model CoveragePlan {
  id                  String @id @default(cuid())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  areaSqm             Int
  floors              Int
  wallLossDb          Int
  rooms               Int?
  wallType            String?
  desiredSpeedMbps    Int?
  deviceCount         Int?
  recommendedAps      Int
  recommendedSwitches Int
  recommendedOutlets  Int?

  floorPlanJson       Json?
  recommendationsJson Json?

  equipmentCost Int?
  installCost   Int?
  totalCost     Int?

  coverageQuality String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum EquipmentType {
  ROUTER
  ACCESS_POINT
  MESH_NODE
}

model NetworkEquipment {
  id              String        @id @default(cuid())
  name            String
  manufacturer    String
  deviceType      EquipmentType
  price           Int
  coverageRadiusM Float
  maxUsers        Int
  imageUrl        String?
  specs           Json?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([deviceType])
}

model InstallationPricing {
  id        String @id @default(cuid())

  name      String
  unit      String
  basePrice Int

  currency String @default("MRU")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([unit])
}

enum RequestType {
  SITE_SURVEY
  INSTALLATION
  CONSULTATION
}

enum RequestStatus {
  NEW
  CONTACTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ServiceRequest {
  id String @id @default(cuid())

  type   RequestType
  status RequestStatus @default(NEW)

  name    String
  email   String?
  phone   String?
  address String?
  notes   String?

  estimateId String?

  userId Int?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model PortalProject {
  id String @id @default(cuid())

  userId Int

  title   String
  summary String?

  status   String @default("active")
  progress Int    @default(0)

  startedAt DateTime?
  dueAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model SupportTicket {
  id String @id @default(cuid())

  userId Int

  title       String
  description String

  status   String @default("open")
  priority String @default("normal")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updates SupportTicketUpdate[]

  @@index([userId])
  @@index([status])
}

model SupportTicketUpdate {
  id String @id @default(cuid())

  ticketId String

  authorId Int?

  message String

  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model PortalDocument {
  id String @id @default(cuid())

  userId Int

  title    String
  fileType String?
  url      String
  sizeBytes Int?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
